{
  "name": "bdbox-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild frontend/src/app.ts --bundle --minify --outdir=bdbox/view/server/static/ --loader:.png=dataurl",
    "dev": "esbuild frontend/src/app.ts --bundle --watch --outdir=bdbox/view/server/static/ --loader:.png=dataurl",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint --fix --cache frontend/ utils/assets/",
    "format": "prettier --write frontend/ utils/assets/ package.json eslint.config.js tsconfig.json"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "alpinejs": "^3.15.12",
    "golden-layout": "^2.6.0",
    "jedison": "^1.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
