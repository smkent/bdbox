{
  "name": "bdbox-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild frontend/src/app.ts --bundle --minify --outdir=bdbox/view/static/ --loader:.png=dataurl",
    "dev": "esbuild frontend/src/app.ts --bundle --watch --outdir=bdbox/view/static/ --loader:.png=dataurl",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint --fix --cache frontend/",
    "format": "prettier --write frontend/ package.json eslint.config.js tsconfig.json"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "alpinejs": "^3.14.0",
    "golden-layout": "^2.6.0",
    "jedison": "^1.11.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
